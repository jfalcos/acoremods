###############################################################################
# mod-item-infusion — sacrifice gear to empower gear, at the risk of losing it
###############################################################################
#
# Infusion transfers a fraction of a donor item's native stats onto a target
# item as permanent per-instance bonuses (mod-property-override rows,
# source 'mix'). The donor is always destroyed. Each attempt rolls against a
# destruction chance for the TARGET that grows the more the target has
# already been infused — risk is the balance mechanism instead of a hard cap
# (mod-paragon's coin upgrades keep their hard 30% cap; infusion can go
# beyond it if you keep winning the roll).
#
# Risk model:
#   f     = target's accumulated mix points / native (Quality, ItemLevel)
#           stat budget (same corpus-fitted budget the paragon cap uses)
#   risk  = clamp(BasePercent + SlopePercent * (f / PivotPercent)^Exponent,
#                 BasePercent, MaxPercent)
#   Defaults: 5% on a fresh item, 50% once mix fill reaches the paragon-cap-
#   equivalent 30%, growing toward 90% beyond it.
# Mitigation (chosen per attempt, consumed win or lose):
#   each Paragon Coin: -CoinReductionPercent risk
#   each substance:    its configured reduction
#   floored at FloorPercent — no attempt is ever fully safe.

ItemInfusion.Enable = 1
ItemInfusion.Debug = 0

# Minimum character level to infuse. Low on purpose: the mastery penalty
# below (not this gate) is what protects low levels from gear beyond them,
# and the lowbie loop — feeding offspec quest rewards into your weapon at
# ~5% risk — is meant to be available early.
ItemInfusion.MinLevel = 10

# Mastery: gear beyond the character's level is riskier to infuse. An item
# counts as mastered once charLevel >= item RequiredLevel + GraceLevels;
# below that, each missing level adds PenaltyPerLevelPercent risk, capped
# at MaxPenaltyPercent. The WORSE of target and donor decides (so neither
# end of a twink-funnel can be smuggled). Characters at or above
# MasteredAtLevel are exempt (0 disables the exemption) — with the default
# 80, endgame risk math is identical to the pre-mastery tuning.
# Worked examples (defaults): L25 on own L20 gear -> +0%; L25 fed a L40
# BoE donor -> +30% (capped); L80 on anything -> +0%.
ItemInfusion.Mastery.GraceLevels = 10
ItemInfusion.Mastery.PenaltyPerLevelPercent = 2
ItemInfusion.Mastery.MaxPenaltyPercent = 30
ItemInfusion.Mastery.MasteredAtLevel = 80

# Creature entry of the Alchemist NPC offering the gossip UI.
ItemInfusion.AlchemistEntry = 96010

# Percent of the donor's native stats transferred (ceil-rounded per stat).
# 35% keeps a same-ilvl donor's contribution comparable to one or two coin
# upgrades, so sacrificing gear competes with (not dominates) the coin path.
ItemInfusion.EfficiencyPercent = 35

# Risk curve (see model above).
ItemInfusion.Risk.BasePercent = 5
ItemInfusion.Risk.SlopePercent = 45
ItemInfusion.Risk.PivotPercent = 30
ItemInfusion.Risk.Exponent = 1.6
ItemInfusion.Risk.MaxPercent = 90
ItemInfusion.Risk.FloorPercent = 2

# Risk removed per Paragon Coin pledged on the attempt. Coins are NOT
# tier-banded on purpose: they are account-pooled endgame currency, so a
# low-level spending them pays a real price.
ItemInfusion.CoinReductionPercent = 5

# Substances are tier-banded like every native consumable: a reagent only
# stabilizes gear whose (worse of target/donor) RequiredLevel is at most
# the reagent's own ItemLevel + this grace. With 15: Minor Healing Potion
# (ilvl 5) covers gear to req 20, Superior (ilvl 35) to req 50, Runic
# potions (ilvl ~70+) cover everything - copper-priced potions can never
# insure an epic.
ItemInfusion.SubstanceGraceLevels = 15

# Stabilizing substances: "itemId:riskReductionPercent,..." — native
# consumables handed over per attempt. Defaults span all level bands so
# lowbies have affordable insurance from their own world:
#   118 Minor Healing Potion (-5), 858 Lesser Healing Potion (-5),
#   3928 Superior Healing Potion (-5), 33447 Runic Healing Potion (-5),
#   33448 Runic Mana Potion (-5), 36906 Frost Lotus (-10),
#   35625 Eternal Life (-20).
# Ids without a live item_template row are ignored at the menu.
ItemInfusion.Substances = "118:5,858:5,3928:5,33447:5,33448:5,36906:10,35625:20"
